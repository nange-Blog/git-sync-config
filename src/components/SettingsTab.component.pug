h3 Sync Config

div.sync-config-settings-tab
    .row
        .col-md-7
            .form-line
                .header
                    .title Type
                select.form-control(
                    [(ngModel)]='config.store.syncConfig.type',
                    (ngModelChange)='config.save()'
                )
                    option(ngValue='Off') Off
                    option(ngValue='GitHub') GitHub
                    option(ngValue='Gitee') Gitee
                    option(ngValue='GitLab') GitLab

    .row(*ngIf='config.store.syncConfig.type !== "Off"')
        .col-md-7
            .form-line(*ngIf='config.store.syncConfig.type == "GitLab"')
                .header
                    .title Instance URL
                input.form-control(
                    type='text',
                    placeholder="https://gitlab.com",
                    [(ngModel)]='config.store.syncConfig.baseUrl',
                    (ngModelChange)='config.save()',
                )
            .form-line
                .header
                    .title Token
                input.form-control(
                    type='text',
                    placeholder="token",
                    [(ngModel)]='config.store.syncConfig.token',
                    (ngModelChange)='config.save()',
                )
            .form-line
                .header
                    .title Encryption
                    .description Use token to encrypt SSH passwords
                toggle(
                    [(ngModel)]='config.store.syncConfig.encryption',
                    (ngModelChange)='config.save()',
                )
            .form-line
                .header
                    .title Auto Sync
                    .description Automatically sync config when changes detected
                toggle(
                    [(ngModel)]='config.store.syncConfig.autoSync',
                    (ngModelChange)='onAutoSyncToggle()',
                )
            .form-line(*ngIf='config.store.syncConfig.autoSync')
                .header
                    .title Interval
                    .description Check for changes every N minutes
                select.form-control(
                    [(ngModel)]='config.store.syncConfig.autoSyncInterval',
                    (ngModelChange)='onAutoSyncIntervalChange()'
                )
                    option(ngValue=1) 1 min
                    option(ngValue=3) 3 min
                    option(ngValue=5) 5 min
                    option(ngValue=10) 10 min
                    option(ngValue=30) 30 min
            .form-line
                .header
                    .title Gist
                .input-group
                    input.form-control(
                        type='text',
                            placeholder="use existing gist id or auto generate gist id",
                            [(ngModel)]='config.store.syncConfig.gist',
                            (ngModelChange)='config.save()',
                    )
                    .input-group-append(*ngIf='config.store.syncConfig.type !== "Gitee"')
                        button.btn.btn-secondary(
                            (click)='viewGist()',
                            [disabled]="config.store.syncConfig.gist === null || config.store.syncConfig.gist.toString().trim() === ''",
                            )
                            i.fa.fa-fw.fa-eye

            .form-line
                button.btn.btn-outline-primary.mr-3(
                    (click)='sync(true)',
                    [disabled]='isUploading || isDownloading || isAutoSyncing',
                )
                    div.fa.fa-fw.fa-upload(*ngIf='!isUploading')
                    div.fa.fa-cog.fa-spin(*ngIf='isUploading')
                    span.ml-2 Upload config
                .mt-3.d-sm-none
                button.btn.btn-outline-warning(
                    (click)='sync(false)',
                    style={'margin-right':'10px'},
                    [disabled]='isUploading || isDownloading || isAutoSyncing',
                )
                    div.fa.fa-cog.fa-spin(*ngIf='isDownloading')
                    div.fa.fa-fw.fa-download(*ngIf='!isDownloading')
                    span.ml-2 Download config
            .form-line
                p.text-white(*ngIf='isUploading || isDownloading') Syncing
                p.text-white(*ngIf='isAutoSyncing && !isUploading && !isDownloading') Auto syncing
                p.text-white(*ngIf='!(isUploading || isDownloading || isAutoSyncing)') Last sync time : {{ config.store.syncConfig.lastSyncTime }}
            .form-line
                .header
                    .title Sync Logs
                    select.sync-log-max-select(
                        [(ngModel)]='config.store.syncConfig.syncLogMax',
                        (ngModelChange)='onSyncLogMaxChange()'
                    )
                        option(ngValue=3) 3
                        option(ngValue=5) 5
                        option(ngValue=10) 10
                        option(ngValue=20) 20
                .sync-log-box
                    .sync-log-entry(*ngFor='let log of syncLogs')
                        span.log-time {{ log.time }}
                        span.log-direction([class.log-success]='log.success', [class.log-fail]='!log.success') {{ log.direction }}
                        span.log-status {{ log.success ? '✓' : '✗' }}
                        span.log-message {{ log.message }}
